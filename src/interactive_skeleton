#include "yisiscorer.h"

#include <iostream>
#include <vector>
#include <fstream>
#include <string>
#include <ctime>

using namespace std;
using namespace yisi;

int main(const int argc, const char* argv[])
{
   typedef com::masaers::cmdlp::options<eval_options, yisi_options, phrasesim_options> options_type;

   options_type opt(argc,argv);
   if (! opt) {
      return opt.exit_code();
   }

   yisiscorer_t<options_type> yisi(opt);

   string hypsents;
   cin >> hypsents;
   string inpsents;      
   cin >> inpsents;

   cerr << "Tokenizing/SRL-ing hyp ... ";
   srlgraph_t hypsrlgraphs = yisi.hypsrlparse(hypsents);
   cerr << "Done." << endl;

   cerr << "Tokenizing/SRL-ing inp ... ";
   srlgraph_t inpsrlgraphs = yisi.inpsrlparse(inpsents);
   cerr << "Done." << endl;

   vector<srlgraph_t> dummy; //no ref srl graph because we are in YiSi-2 interactive mode

   cerr <<"Scoring...";
   yisigraph_t m;
   m = yisi.align(dummy, hypsrlgraphs, inpsrlgraphs);

   double s = yisi.score(m);
   cerr <<"Done"<<endl;
   cout <<s <<endl;

   return 0;
}
