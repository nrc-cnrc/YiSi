#include "lexsim.h"

#include <iostream>
#include <set>

using namespace std;
using namespace yisi;

int main(int argc, char* argv[])
{
   string lsname = argv[1];
   string lspath = argv[2];
   string test = argv[3];
   
   lexsim_t l(lsname, lspath);
   auto lines = read_file(test);
   int oovToken=0;
   int oovType=0;
   int nToken=0;
   int nType=0;
   set<string> seen;
   set<string> oov;
   for (auto it = lines.begin(); it != lines.end(); it++){
     auto tokens = tokenize(*it);
     for (auto jt = tokens.begin(); jt != tokens.end(); jt++){
       nToken++;
       if (seen.find(*jt)!=seen.end()){
	 if (oov.find(*jt)!=oov.end()){
	   oovToken++;
	 } 
       } else {
	 nType++;
	 seen.insert(*jt);
	 auto v = l.get_wv(*jt, yisi::HYP_MODE);
	 if (!(v.size()>0)){
	   oov.insert(*jt);
	   oovToken++;
	   oovType++;
	 }
       }
     }
   }
   cout << oovType << " "<<oovToken<<" "<<nType<<" "<<nToken<<endl;
   return 0;
}

